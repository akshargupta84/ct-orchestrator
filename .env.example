# =============================================================================
# CT Orchestrator Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control
# =============================================================================

# Anthropic API Key (required)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Anthropic model selection
# Default: claude-sonnet-4-20250514
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# =============================================================================
# Ollama Configuration (for local video analysis)
# =============================================================================

# Ollama server URL (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Vision model for video frame analysis
# Recommended: llava:13b (for 32GB RAM) or llava:7b (for 16GB RAM)
OLLAMA_VISION_MODEL=llava:13b

# =============================================================================
# Database Configuration
# =============================================================================

# SQLite database path (relative to project root)
DATABASE_PATH=data/campaigns.db

# ChromaDB persistence directory
CHROMA_PERSIST_DIR=data/chroma

# =============================================================================
# Application Settings
# =============================================================================

# Debug mode (set to true for verbose logging)
DEBUG=false

# Maximum file upload size in MB
MAX_UPLOAD_SIZE_MB=100

# Number of frames to extract per video for analysis
FRAMES_PER_VIDEO=8

# =============================================================================
# Optional: External Services
# =============================================================================

# If using cloud-hosted ChromaDB
# CHROMA_HOST=your-chroma-host
# CHROMA_PORT=8000

# If using external embedding service
# EMBEDDING_API_KEY=your_embedding_api_key
